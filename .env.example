# ============================================================================
#  Publish With Vaishu — environment variables
#  Copy this file to .env.local and fill in the values.
#  Milestone 1 only needs the two NEXT_PUBLIC_SUPABASE_* values.
# ============================================================================

# --- Supabase (Milestone 1) -------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for admin writes — added in a later milestone.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth.js v5 -------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cloudinary (later milestone) -------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Razorpay (later milestone) ---------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Resend (email) ---------------------------------------------------------
# If blank in dev, emails are logged to the server console instead of sent.
# RESEND_FROM must use a domain verified in your Resend account (add the
# SPF/DKIM DNS records Resend provides) or delivery to real inboxes is rejected.
RESEND_API_KEY=
RESEND_FROM="Publish With Vaishu <noreply@publishwithvaishu.in>"

# --- Admin (single owner account) -------------------------------------------
# Generate the hash: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD',10))"
# IMPORTANT: escape every "$" in the hash as "\$" — Next's env loader performs
# variable expansion, otherwise the value loads empty.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
